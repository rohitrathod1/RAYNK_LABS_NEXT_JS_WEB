// auth.prisma — Admin user model for authentication.

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum AdminStatus {
  PENDING    // registered, awaiting approval
  APPROVED   // can log in
  REJECTED   // registration rejected
  SUSPENDED  // temporarily disabled
}

model Admin {
  id       String      @id @default(cuid())
  name     String
  email    String      @unique
  mobile   String?     @unique
  password String      // bcrypt hashed — never return in API responses
  role     AdminRole   @default(ADMIN)
  status   AdminStatus @default(PENDING)

  // Profile
  imageUrl  String?
  bio       String?
  github    String?
  linkedin  String?
  instagram String?
  youtube   String?
  portfolio String?

  // Approval workflow
  approvedById   String?
  approvedAt     DateTime?
  approvedBy     Admin?    @relation("AdminApprovals", fields: [approvedById], references: [id])
  approvedAdmins Admin[]   @relation("AdminApprovals")

  // RBAC
  permissions UserPermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([role])
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       UserPermission[]
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String

  user       Admin      @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}
