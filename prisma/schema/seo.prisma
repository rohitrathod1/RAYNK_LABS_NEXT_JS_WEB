// ==========================================
// SEO METADATA — per-page SEO settings
// One row per indexed public page (keyed by `page` slug)
// Read by generateMetadata() via resolveSeo() helper
// ==========================================

model SeoMeta {
  id              String   @id @default(cuid())
  page            String   @unique // "home", "about", "products", "blog", "contact", ...
  metaTitle       String
  metaDescription String?  @db.Text
  keywords        String[] // PostgreSQL text[]
  ogTitle         String?
  ogDescription   String?  @db.Text
  ogImage         String?
  twitterCard     String   @default("summary_large_image") // "summary" | "summary_large_image"
  canonicalUrl    String?
  structuredData  Json? // JSON-LD blob
  robots          String   @default("index,follow") // or "noindex,nofollow"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([page])
}
