// portfolio.prisma — Portfolio page CMS and individual projects

model PortfolioPage {
  id        String   @id @default(cuid())
  section   String   @unique       // "hero" | "categories_filter" | "projects_grid" | "testimonials" | "contact_cta"
  title     String?
  content   Json
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model PortfolioProject {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  category    String
  image       String
  liveUrl     String?
  githubUrl   String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isFeatured])
  @@index([isActive])
}
